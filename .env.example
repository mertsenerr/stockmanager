# ─────────────────────────────────────────────────────────────────────────────
# SayımLink — environment variables template
# Copy to backend/.env (or set in Render/Netlify dashboards) for deployment.
# Local development uses backend/appsettings.Development.json instead.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (Atlas in prod, mongodb://localhost:27017 in dev)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=sayimlink

# JWT signing
JWT_SECRET=change-me-to-a-32-plus-char-random-string
JWT_ISSUER=sayimlink-api
JWT_AUDIENCE=sayimlink-app
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=30

# CORS — comma-separated origins (Netlify URL in prod, localhost in dev)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Initial admin (seeded on first run if no admin exists)
SEED_ADMIN_EMAIL=admin@sayimlink.local
SEED_ADMIN_PASSWORD=ChangeMeOnFirstLogin!

# Resend (transactional email — used in Phase 1 password reset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@sayimlink.local

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5080
