{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "sayimlink"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Jwt": {
    "Secret": "REPLACE_ME_WITH_32_PLUS_CHAR_RANDOM_SECRET",
    "Issuer": "sayimlink-api",
    "Audience": "sayimlink-app",
    "AccessTokenMinutes": 60,
    "RefreshTokenDaysRememberMe": 30,
    "RefreshTokenHoursDefault": 8
  },
  "Resend": {
    "ApiKey": "re_xxxxxxxxxxxxxxx",
    "FromEmail": "REPLACE_WITH_VERIFIED_RESEND_ADDRESS@yourdomain.com",
    "FromName": "SayımLink",
    "PasswordResetUrlTemplate": "https://yourdomain.com/reset-password?token={token}"
  },
  "Seed": {
    "AdminEmail": "REPLACE_WITH_BOOTSTRAP_ADMIN@yourdomain.com",
    "AdminPassword": "REPLACE_WITH_STRONG_PASSWORD",
    "AdminName": "Sayım Başkanı"
  }
}
