{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "sayimlink"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Jwt": {
    "Secret": "REPLACE_ME_WITH_32_PLUS_CHAR_RANDOM_SECRET",
    "Issuer": "sayimlink-api",
    "Audience": "sayimlink-app",
    "AccessTokenMinutes": 60,
    "RefreshTokenDaysRememberMe": 30,
    "RefreshTokenHoursDefault": 8
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "no-reply@sayimlink.local",
    "FromName": "SayımLink",
    "PasswordResetUrlTemplate": "http://localhost:4200/reset-password?token={token}"
  },
  "Seed": {
    "AdminEmail": "admin@sayimlink.local",
    "AdminPassword": "ChangeMeOnFirstLogin1!",
    "AdminName": "Sayım Başkanı"
  }
}
