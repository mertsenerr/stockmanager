# Cloudflare Pages reads this file from the publish dir and applies the headers
# to matching responses. See:
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Backend already sets CSP / X-Frame / HSTS on JSON responses, but Cloudflare
# Pages serves the HTML shell that loads Angular — the same defences need to
# ride on those responses too, otherwise the SPA host is the soft target
# (clickjacking, CSP-less script injection if a CDN ever leaks).

/*
  # CF Pages injects `Access-Control-Allow-Origin: *` on every static response
  # by default. Pentest W03 flagged it as latent risk: harmless for the
  # current all-public asset surface, but if a dynamic / per-user response
  # is ever served from this origin (an edge function, an SSR page, etc.)
  # the wildcard would let any site read its body. The SPA only fetches the
  # same-origin bundle plus the explicit API origin (which sets its own
  # strict allowlist), so stripping ACAO here breaks nothing.
  ! Access-Control-Allow-Origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(self), camera=(self), display-capture=(self), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data:; connect-src 'self' https://stockmanager-d6nm.onrender.com wss://stockmanager-d6nm.onrender.com https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  # Default: don't cache HTML (any path that returns the SPA shell via the
  # /index.html fallback — /ozel-raporlar/belge-tipleri, /login, /…). Without
  # this, browsers/CDN keep serving an old index.html that points at chunk
  # filenames the new deployment no longer has, breaking the SPA after every
  # deploy until users clear cache.
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed bundle assets are immutable — Angular changes the filename whenever
# content changes — so long-cache is safe and keeps deploys fast. These rules
# come after /* so they win for matching paths.
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon — moderate cache, in case it changes
/favicon.ico
  Cache-Control: public, max-age=86400
